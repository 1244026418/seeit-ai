{$DOMAIN} {
    encode gzip

    handle /mcp* {
        reverse_proxy mcp:8001
    }

    handle /.well-known/oauth-protected-resource* {
        reverse_proxy mcp:8001
    }

    handle {
        reverse_proxy frontend:80
    }

    header {
        -Server
        X-Content-Type-Options "nosniff"
        X-Frame-Options "SAMEORIGIN"
        Referrer-Policy "strict-origin-when-cross-origin"
    }

    log {
        output stdout
        format json
    }
}
