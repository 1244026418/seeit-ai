# 复制为 deploy/.env.production 后填写，不要提交真实文件。
APP_ENV=production
DOMAIN=video.example.com
DEBIAN_MIRROR=deb.debian.org
PIP_INDEX_URL=https://pypi.org/simple
NPM_REGISTRY=https://registry.npmjs.org
MYSQL_DATABASE=media_db
MYSQL_USER=seeit_app
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-another-long-random-password
DATABASE_URL=mysql+pymysql://seeit_app:replace-with-a-long-random-password@mysql:3306/media_db?charset=utf8mb4
REDIS_PASSWORD=replace-with-a-long-random-password
REDIS_URL=redis://:replace-with-a-long-random-password@redis:6379/0
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRE_HOURS=24
ROOT_PATH=/api
CORS_ALLOWED_ORIGINS=https://video.example.com
UPLOAD_ROOT=/data/uploads
MAX_CHUNK_BYTES=5242880
MAX_UPLOAD_BYTES=536870912
MAX_VIDEO_DURATION_SECONDS=600
VALIDATE_VIDEO_CONTENT=true
UPLOAD_SESSION_TTL_HOURS=24
MAX_ANALYSIS_ATTEMPTS=3
STALE_TASK_SECONDS=1800
QUEUED_TASK_FALLBACK_SECONDS=10
QUEUE_WATCHDOG_INTERVAL_SECONDS=2
QUEUE_WATCHDOG_BATCH_SIZE=10
AUTO_CREATE_SCHEMA=false
BILIBILI_IMPORT_ENABLED=true
BILIBILI_MAX_DURATION_SECONDS=600
BILIBILI_MAX_FILE_BYTES=536870912
BILIBILI_IMPORT_ATTEMPTS=3
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=
AI_MODEL=deepseek-v4-flash
AI_THINKING_MODE=disabled
AI_REQUEST_TIMEOUT_SECONDS=180
AGENT_MAX_TOOL_STEPS=8
AGENT_MEMORY_MAX_MESSAGES=12
AGENT_HISTORY_MAX_MESSAGES=200
ASR_BASE_URL=
ASR_API_KEY=
ASR_MODEL=TeleAI/TeleSpeechASR
LOCAL_ASR_ENABLED=true
LOCAL_ASR_MODEL=base
LOCAL_ASR_MODEL_ROOT=/data/models
LOCAL_ASR_DEVICE=cpu
LOCAL_ASR_COMPUTE_TYPE=int8
LOCAL_ASR_CPU_THREADS=4
LOCAL_ASR_LANGUAGE=zh
LOCAL_ASR_BEAM_SIZE=5
LOCAL_ASR_VAD_FILTER=true
LOCAL_ASR_PRELOAD=true
LOCAL_ASR_RELEASE_BEFORE_OCR=true
LOCAL_ASR_INITIAL_PROMPT=以下是中文技术视频的逐字稿，涉及 GPT、Sol、Terra、Luna、Reasoning Effort、Token 和 API。请使用自然标点。
LOCAL_ASR_HOTWORDS=
OCR_ENABLED=true
OCR_INTERVAL_SECONDS=30
PADDLEOCR_MODEL_ROOT=/data/models/paddlex
PADDLEOCR_MODEL_SOURCE=bos
PADDLEOCR_DETECTION_MODEL=PP-OCRv5_mobile_det
PADDLEOCR_RECOGNITION_MODEL=PP-OCRv5_mobile_rec
PADDLEOCR_DEVICE=cpu
PADDLEOCR_CPU_THREADS=4
PADDLEOCR_ENABLE_MKLDNN=true
PADDLEOCR_CONFIDENCE_THRESHOLD=0.65
PADDLEOCR_DEDUP_THRESHOLD=0.88
PADDLEOCR_MIN_TEXT_LENGTH=2
PADDLEOCR_MAX_FRAMES=20
PADDLEOCR_FRAME_MAX_WIDTH=960
PADDLEOCR_PROCESS_TIMEOUT_SECONDS=600
ROCKETMQ_NAMESERVER=rmqnamesrv:9876
ROCKETMQ_TOPIC=video-analysis-topic
ROCKETMQ_PRODUCER_GROUP=seeit-python-producer
ROCKETMQ_CONSUMER_GROUP=seeit-python-consumer
ROCKETMQ_CONSUME_THREADS=1
LOCAL_EXECUTOR_WORKERS=1
WORKER_CPU_LIMIT=3.0
WORKER_MEMORY_LIMIT=2560m
LOG_LEVEL=INFO
